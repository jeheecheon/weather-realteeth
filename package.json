{
  "name": "weather-realteeth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "concurrently -n app,steiger -c blue,yellow \"pnpm dev:app\" \"pnpm dev:steiger\"",
    "dev:app": "vite",
    "dev:steiger": "steiger ./src --watch",
    "build": "pnpm lint:steiger && tsc && vite build",
    "preview": "vite preview",
    "start": "pnpm preview",
    "lint": "pnpm lint:eslint && pnpm lint:steiger",
    "lint:eslint": "eslint",
    "lint:steiger": "steiger ./src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-kr": "^5.2.10",
    "@fontsource-variable/roboto": "^5.2.10",
    "@fontsource-variable/roboto-mono": "^5.2.9",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use": "^17.6.0",
    "synced-storage": "^1.3.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "steiger": "^0.5.11",
    "tailwindcss": "^4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.5.0"
  }
}
